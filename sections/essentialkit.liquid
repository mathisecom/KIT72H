{% comment %}
  Section : Les essentiels du sac d'urgence
  Fichier  : sections/essentials-list.liquid
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@600;700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} .ess-s {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_v }}px {{ section.settings.padding_h }}px;
  }

  #shopify-section-{{ section.id }} .ess-s__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── TAG ── */
  #shopify-section-{{ section.id }} .ess-s__tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'DM Sans', sans-serif;
    color: {{ section.settings.tag_color }};
    font-size: {{ section.settings.tag_size }}px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: {{ section.settings.tag_mb }}px;
  }

  {% if section.settings.show_tag_line %}
  #shopify-section-{{ section.id }} .ess-s__tag::before {
    content: '';
    width: {{ section.settings.tag_line_width }}px;
    height: 2px;
    background-color: {{ section.settings.tag_color }};
    border-radius: 1px;
    display: inline-block;
  }
  {% endif %}

  /* ── TITRE ── */
  #shopify-section-{{ section.id }} .ess-s__title {
    font-family: 'Epilogue', sans-serif;
    font-size: {{ section.settings.title_size }}px;
    font-weight: {{ section.settings.title_weight }};
    color: {{ section.settings.title_color }};
    line-height: 1.2;
    margin-bottom: {{ section.settings.title_mb }}px;
    max-width: {{ section.settings.title_max_width }}px;
  }

  /* ── LEAD ── */
  #shopify-section-{{ section.id }} .ess-s__lead {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ section.settings.lead_size }}px;
    font-weight: 300;
    color: {{ section.settings.lead_color }};
    line-height: 1.7;
    max-width: {{ section.settings.lead_max_width }}px;
    margin-bottom: {{ section.settings.lead_mb }}px;
  }

  /* ── LISTE ── */
  #shopify-section-{{ section.id }} .ess-s__list {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.items_gap }}px;
  }

  /* ── ITEM ── */
  #shopify-section-{{ section.id }} .ess-s__item {
    display: flex;
    align-items: center;
    gap: {{ section.settings.item_gap }}px;
    background-color: {{ section.settings.item_bg }};
    border-radius: {{ section.settings.item_radius }}px;
    padding: {{ section.settings.item_pad_v }}px {{ section.settings.item_pad_h }}px;
    border-left: {{ section.settings.item_border_width }}px solid {{ section.settings.item_border_color }};
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  {% if section.settings.item_hover %}
  #shopify-section-{{ section.id }} .ess-s__item:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,.08);
    transform: translateX(3px);
  }
  {% endif %}

  /* ── ICÔNE ── */
  #shopify-section-{{ section.id }} .ess-s__icon {
    font-size: {{ section.settings.icon_size }}px;
    flex-shrink: 0;
    width: {{ section.settings.icon_box }}px;
    text-align: center;
  }

  /* ── TEXTE ── */
  #shopify-section-{{ section.id }} .ess-s__item-title {
    font-family: 'Epilogue', sans-serif;
    font-size: {{ section.settings.item_title_size }}px;
    font-weight: {{ section.settings.item_title_weight }};
    color: {{ section.settings.item_title_color }};
    line-height: 1.3;
    margin-bottom: 3px;
  }

  #shopify-section-{{ section.id }} .ess-s__item-note {
    font-family: 'DM Sans', sans-serif;
    font-size: {{ section.settings.item_note_size }}px;
    font-weight: 400;
    color: {{ section.settings.item_note_color }};
    line-height: 1.5;
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: {{ section.settings.breakpoint }}px) {
    #shopify-section-{{ section.id }} .ess-s {
      padding: {{ section.settings.padding_v | divided_by: 1.4 | round }}px {{ section.settings.padding_h | divided_by: 1.5 | round }}px;
    }
    #shopify-section-{{ section.id }} .ess-s__title {
      font-size: {{ section.settings.title_size | times: 0.75 | round }}px;
    }
    #shopify-section-{{ section.id }} .ess-s__item {
      padding: {{ section.settings.item_pad_v | minus: 2 }}px {{ section.settings.item_pad_h | minus: 4 }}px;
    }
  }
</style>

<section class="ess-s">
  <div class="ess-s__inner">

    {%- if section.settings.tag != blank -%}
      <div class="ess-s__tag">{{ section.settings.tag }}</div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <{{ section.settings.title_tag }} class="ess-s__title">
        {{ section.settings.title }}
      </{{ section.settings.title_tag }}>
    {%- endif -%}

    {%- if section.settings.lead != blank -%}
      <p class="ess-s__lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ess-s__list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'item' -%}
            <div class="ess-s__item" {{ block.shopify_attributes }}
              style="
                {% if block.settings.item_bg != blank %}background-color: {{ block.settings.item_bg }};{% endif %}
                {% if block.settings.border_color != blank %}border-left-color: {{ block.settings.border_color }};{% endif %}
              ">
              {%- if block.settings.icon != blank -%}
                <div class="ess-s__icon">{{ block.settings.icon }}</div>
              {%- endif -%}
              <div>
                {%- if block.settings.title != blank -%}
                  <div class="ess-s__item-title"
                    style="{% if block.settings.title_color != blank %}color: {{ block.settings.title_color }};{% endif %}">
                    {{ block.settings.title }}
                  </div>
                {%- endif -%}
                {%- if block.settings.note != blank -%}
                  <div class="ess-s__item-note"
                    style="{% if block.settings.note_color != blank %}color: {{ block.settings.note_color }};{% endif %}">
                    {{ block.settings.note }}
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

