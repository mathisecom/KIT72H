{% comment %}
  Section: Features Bar
  Description: Barre de caractéristiques avec icônes SVG et textes - PC & Mobile responsive
{% endcomment %}

<section class="features-bar" id="features-bar-{{ section.id }}">
  <div class="features-bar__container">
    {% for block in section.blocks %}
      {% if block.type == 'feature' %}
        <div class="features-bar__item" {{ block.shopify_attributes }}>
          <div class="features-bar__icon">
            {% if block.settings.icon == 'camera' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
                <circle cx="12" cy="13" r="4"/>
              </svg>
            {% elsif block.settings.icon == 'check' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
                <circle cx="12" cy="12" r="10"/>
              </svg>
            {% elsif block.settings.icon == 'medal' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="15" r="5"/>
                <path d="M8.56 2.9A7 7 0 0 1 19 9v2h2"/>
                <path d="M3 9h2v2a7 7 0 0 0 3.13 5.83"/>
                <path d="m7.532 18.548 1.218 2.107a1 1 0 0 0 1.2.376l1.05-.493 1.05.493a1 1 0 0 0 1.2-.376l1.218-2.107"/>
              </svg>
            {% elsif block.settings.icon == 'droplet' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>
              </svg>
            {% elsif block.settings.icon == 'activity' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
              </svg>
            {% elsif block.settings.icon == 'shield' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
              </svg>
            {% elsif block.settings.icon == 'star' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            {% elsif block.settings.icon == 'truck' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="1" y="3" width="15" height="13"/>
                <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/>
                <circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
            {% elsif block.settings.icon == 'tool' %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
              </svg>
            {% else %}
              <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 8 12 12 14 14"/>
              </svg>
            {% endif %}
          </div>
          <p class="features-bar__text">{{ block.settings.text }}</p>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
  #features-bar-{{ section.id }} {
    --fb-bg: {{ section.settings.background_color }};
    --fb-text: {{ section.settings.text_color }};
    --fb-icon: {{ section.settings.icon_color }};
    --fb-border: {{ section.settings.border_color }};
    --fb-padding-v: {{ section.settings.padding_vertical }}px;
    --fb-font-size: {{ section.settings.font_size }}px;
  }

  .features-bar {
    background-color: var(--fb-bg);
    border-top: 1px solid var(--fb-border);
    border-bottom: 1px solid var(--fb-border);
    padding: var(--fb-padding-v) 20px;
    width: 100%;
    box-sizing: border-box;
  }

  .features-bar__container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 24px 16px;
  }

  .features-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1 1 140px;
    max-width: 180px;
    gap: 12px;
  }

  .features-bar__icon {
    color: var(--fb-icon);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    height: 44px;
  }

  .features-bar__icon svg {
    width: 36px;
    height: 36px;
    display: block;
  }

  .features-bar__text {
    color: var(--fb-text);
    font-size: var(--fb-font-size);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    line-height: 1.4;
    margin: 0;
    padding: 0;
  }

  /* Tablet */
  @media (max-width: 900px) {
    .features-bar__container {
      gap: 20px 12px;
    }
    .features-bar__item {
      flex: 1 1 120px;
      max-width: 160px;
    }
    .features-bar__text {
      font-size: calc(var(--fb-font-size) - 1px);
    }
  }

  /* Mobile */
  @media (max-width: 600px) {
    .features-bar {
      padding: 20px 16px;
    }
    .features-bar__container {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 12px;
    }
    .features-bar__item {
      flex: none;
      max-width: 100%;
    }
    /* Si nombre impair, centrer le dernier élément */
    .features-bar__item:last-child:nth-child(odd) {
      grid-column: 1 / -1;
    }
    .features-bar__text {
      font-size: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "Barre de caractéristiques",
  "tag": "section",
  "class": "section-features-bar",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Apparence"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur des icônes",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Couleur des bordures",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Espacement vertical",
      "default": 30
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 9,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Taille du texte",
      "default": 11
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Caractéristique",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icône",
          "options": [
            { "value": "camera", "label": "📷 Appareil photo" },
            { "value": "check", "label": "✅ Validation / Approuvé" },
            { "value": "medal", "label": "🏅 Médaille / Robustesse" },
            { "value": "droplet", "label": "💧 Goutte / Étanche" },
            { "value": "activity", "label": "〰️ Activité / Signal" },
            { "value": "shield", "label": "🛡️ Bouclier / Protection" },
            { "value": "star", "label": "⭐ Étoile / Qualité" },
            { "value": "truck", "label": "🚚 Livraison" },
            { "value": "tool", "label": "🔧 Outil / Maintenance" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "CARACTÉRISTIQUE DU PRODUIT"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barre de caractéristiques",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "camera",
            "text": "CONÇU PAR DES EXPERTS DES SITUATIONS D'URGENCE"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "check",
            "text": "TESTÉ & APPROUVÉ PAR DES PROFESSIONNELS"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "medal",
            "text": "EQUIPEMENT 100% ROBUSTE"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "droplet",
            "text": "SAC COMPLÈTEMENT ÉTANCHE"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "activity",
            "text": "100% PRÊT À L'USAGE / 0% D'ENTRETIEN"
          }
        }
      ]
    }
  ]
}
{% endschema %}