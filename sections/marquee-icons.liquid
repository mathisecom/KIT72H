{% comment %}
  Section : Bandeau défilant avec icônes
  Fichier  : sections/marquee-icons.liquid
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} .marquee-bar {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_v }}px 0;
    overflow: hidden;
    position: relative;
    width: 100%;
    border-top: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
    border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
  }

  /* Dégradés flou sur les bords */
  {% if section.settings.show_fade %}
  #shopify-section-{{ section.id }} .marquee-bar::before,
  #shopify-section-{{ section.id }} .marquee-bar::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: {{ section.settings.fade_width }}px;
    z-index: 2;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .marquee-bar::before {
    left: 0;
    background: linear-gradient(to right, {{ section.settings.background_color }}, transparent);
  }
  #shopify-section-{{ section.id }} .marquee-bar::after {
    right: 0;
    background: linear-gradient(to left, {{ section.settings.background_color }}, transparent);
  }
  {% endif %}

  #shopify-section-{{ section.id }} .marquee-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: marquee-scroll-{{ section.id }} {{ section.settings.speed }}s linear infinite;
    {% if section.settings.direction == 'right' %}
    animation-direction: reverse;
    {% endif %}
  }

  #shopify-section-{{ section.id }} .marquee-track:hover {
    {% if section.settings.pause_on_hover %}
    animation-play-state: paused;
    {% endif %}
  }

  @keyframes marquee-scroll-{{ section.id }} {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  #shopify-section-{{ section.id }} .marquee-item {
    display: flex;
    align-items: center;
    gap: {{ section.settings.icon_text_gap }}px;
    white-space: nowrap;
    padding: 0 {{ section.settings.item_padding }}px;
  }

  #shopify-section-{{ section.id }} .marquee-item__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: {{ section.settings.icon_color }};
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
  }

  #shopify-section-{{ section.id }} .marquee-item__icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: {{ section.settings.icon_stroke }}px;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #shopify-section-{{ section.id }} .marquee-item__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .marquee-item__text {
    font-size: {{ section.settings.font_size }}px;
    font-weight: {{ section.settings.font_weight }};
    color: {{ section.settings.text_color }};
    text-transform: {{ section.settings.text_transform }};
    letter-spacing: {{ section.settings.letter_spacing }}em;
    line-height: 1;
  }

  #shopify-section-{{ section.id }} .marquee-item__text strong {
    font-weight: 800;
    color: {{ section.settings.highlight_color }};
  }

  /* Séparateur entre items */
  #shopify-section-{{ section.id }} .marquee-sep {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: {{ section.settings.sep_color }};
    width: {{ section.settings.sep_size }}px;
    height: {{ section.settings.sep_size }}px;
    opacity: {{ section.settings.sep_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .marquee-sep svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
</style>

{%- assign has_blocks = false -%}
{%- for block in section.blocks -%}
  {%- if block.settings.text != blank -%}
    {%- assign has_blocks = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

{%- if has_blocks -%}
<div class="marquee-bar">
  <div class="marquee-track" aria-hidden="true">

    {%- comment %} On duplique 2x pour le défilement infini sans saut {%- endcomment %}
    {%- for _pass in (1..2) -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.text != blank -%}

          {%- comment %} SÉPARATEUR avant chaque item (sauf si désactivé) {%- endcomment %}
          {%- if section.settings.show_separator -%}
            <span class="marquee-sep">
              {%- case section.settings.separator_style -%}
                {%- when 'dot' -%}
                  <svg viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>
                {%- when 'star' -%}
                  <svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z"/></svg>
                {%- when 'diamond' -%}
                  <svg viewBox="0 0 24 24"><path d="M12 2L22 12 12 22 2 12z"/></svg>
                {%- when 'dash' -%}
                  <svg viewBox="0 0 24 8"><rect x="0" y="3" width="24" height="2" rx="1"/></svg>
                {%- when 'flower' -%}
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M12 2a3 3 0 0 1 0 6 3 3 0 0 1 0-6zM12 16a3 3 0 0 1 0 6 3 3 0 0 1 0-6zM2 12a3 3 0 0 1 6 0 3 3 0 0 1-6 0zM16 12a3 3 0 0 1 6 0 3 3 0 0 1-6 0z"/></svg>
                {%- when 'none' -%}
                {%- else -%}
                  <svg viewBox="0 0 8 8"><circle cx="4" cy="4" r="3"/></svg>
              {%- endcase -%}
            </span>
          {%- endif -%}

          <span class="marquee-item" {{ block.shopify_attributes }}>

            {%- comment %} ICÔNE {%- endcomment %}
            {%- if block.settings.icon_svg != blank -%}
              <span class="marquee-item__icon" style="color: {{ block.settings.icon_color | default: section.settings.icon_color }};">
                {{ block.settings.icon_svg }}
              </span>
            {%- elsif block.settings.icon_image != blank -%}
              <span class="marquee-item__icon" style="color: {{ block.settings.icon_color | default: section.settings.icon_color }};">
                <img src="{{ block.settings.icon_image | image_url: width: 60 }}" alt="" loading="lazy">
              </span>
            {%- elsif block.settings.icon_emoji != blank -%}
              <span class="marquee-item__icon" style="font-size: {{ section.settings.icon_size }}px; width: auto; height: auto;">
                {{ block.settings.icon_emoji }}
              </span>
            {%- endif -%}

            {%- comment %} TEXTE {%- endcomment %}
            <span class="marquee-item__text"
              {%- if block.settings.text_color != blank %} style="color: {{ block.settings.text_color }};"{% endif -%}
            >
              {{ block.settings.text }}
            </span>

          </span>

        {%- endif -%}
      {%- endfor -%}
    {%- endfor -%}

  </div>
</div>
{%- endif -%}

{% schema %}
{
  "name": "Bandeau défilant",
  "tag": "section",
  "class": "section-marquee-icons",
  "settings": [
    {
      "type": "header",
      "content": "🎨 Apparence générale"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte (par défaut)",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Couleur du texte mis en valeur (<strong>)",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Couleur des icônes (par défaut)",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "✍️ Typographie"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Taille du texte (px)",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 13
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Graisse du texte",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Casse du texte",
      "options": [
        { "value": "none", "label": "Normal" },
        { "value": "uppercase", "label": "MAJUSCULES" },
        { "value": "capitalize", "label": "Premières Lettres" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Espacement des lettres",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 5,
      "info": "Valeur × 0.01em (ex: 5 = 0.05em)"
    },
    {
      "type": "header",
      "content": "🔷 Icônes"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Taille des icônes (px)",
      "min": 12,
      "max": 40,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "icon_stroke",
      "label": "Épaisseur trait SVG",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2,
      "info": "S'applique aux icônes SVG stroke uniquement"
    },
    {
      "type": "range",
      "id": "icon_text_gap",
      "label": "Espace icône ↔ texte (px)",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "➖ Séparateur"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Afficher les séparateurs",
      "default": true
    },
    {
      "type": "select",
      "id": "separator_style",
      "label": "Style du séparateur",
      "options": [
        { "value": "dot",     "label": "● Point" },
        { "value": "star",    "label": "★ Étoile" },
        { "value": "diamond", "label": "◆ Diamant" },
        { "value": "dash",    "label": "— Tiret" },
        { "value": "flower",  "label": "✿ Fleur" },
        { "value": "none",    "label": "Aucun (espace seulement)" }
      ],
      "default": "dot"
    },
    {
      "type": "color",
      "id": "sep_color",
      "label": "Couleur du séparateur",
      "default": "#cccccc"
    },
    {
      "type": "range",
      "id": "sep_size",
      "label": "Taille du séparateur (px)",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 7
    },
    {
      "type": "range",
      "id": "sep_opacity",
      "label": "Opacité du séparateur (%)",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 70
    },
    {
      "type": "header",
      "content": "▶️ Animation"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Durée d'un cycle (secondes)",
      "min": 5,
      "max": 120,
      "step": 5,
      "default": 30,
      "info": "Plus la valeur est élevée, plus le défilement est lent"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Sens de défilement",
      "options": [
        { "value": "left",  "label": "← Gauche (défaut)" },
        { "value": "right", "label": "→ Droite" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause au survol (desktop)",
      "default": true
    },
    {
      "type": "header",
      "content": "🌫️ Dégradés sur les bords"
    },
    {
      "type": "checkbox",
      "id": "show_fade",
      "label": "Afficher les dégradés de bord",
      "default": true
    },
    {
      "type": "range",
      "id": "fade_width",
      "label": "Largeur du dégradé (px)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "header",
      "content": "📐 Espacements & Bordures"
    },
    {
      "type": "range",
      "id": "padding_v",
      "label": "Espacement vertical (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 10
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Espacement entre les items (px)",
      "min": 8,
      "max": 80,
      "step": 4,
      "default": 28
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Épaisseur des bordures (px)",
      "min": 0,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Couleur des bordures",
      "default": "#e5e5e5"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Élément",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texte",
          "default": "LIVRAISON EXPRESS OFFERTE",
          "info": "Entourez un mot de <strong>…</strong> pour le mettre en valeur"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Couleur du texte (override)",
          "info": "Laissez vide pour utiliser la couleur globale"
        },
        {
          "type": "header",
          "content": "Icône"
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icône SVG",
          "info": "Priorité 1 — collez du SVG (ex : depuis heroicons.com). Laissez vide pour utiliser image ou emoji."
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Image icône",
          "info": "Priorité 2 — si pas de SVG. PNG transparent recommandé."
        },
        {
          "type": "text",
          "id": "icon_emoji",
          "label": "Emoji icône",
          "info": "Priorité 3 — si ni SVG ni image. Ex : 🚚 🛡️ ⭐"
        },
        {
          "type": "color",
          "id": "icon_color",
          "label": "Couleur de l'icône (override)",
          "info": "Laissez vide pour utiliser la couleur globale"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bandeau défilant",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "text": "LIVRAISON EXPRESS OFFERTE",
            "icon_svg": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><rect x='1' y='3' width='15' height='13' rx='1'/><path d='M16 8h4l3 5v4h-7V8z'/><circle cx='5.5' cy='18.5' r='2.5'/><circle cx='18.5' cy='18.5' r='2.5'/></svg>"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "SUPPORT TECHNIQUE 24H/24",
            "icon_svg": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7a2 2 0 0 1 1.72 2.01z'/></svg>"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "GARANTIE 3 ANS",
            "icon_svg": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/></svg>"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "100% SATISFAIT OU REMBOURSÉ !",
            "icon_svg": "<svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M12 22C6.48 22 2 17.52 2 12S6.48 2 12 2s10 4.48 10 10-4.48 10-10 10z'/><path d='M8 14s1.5 2 4 2 4-2 4-2'/><line x1='9' y1='9' x2='9.01' y2='9'/><line x1='15' y1='9' x2='15.01' y2='9'/></svg>"
          }
        },
        {
          "type": "item",
          "settings": {
            "text": "MARQUE FRANÇAISE",
            "icon_emoji": "🇫🇷"
          }
        }
      ]
    }
  ]
}
{% endschema %}