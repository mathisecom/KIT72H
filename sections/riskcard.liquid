      "min": 600,
      "max": 1024,
      "step": 8,
      "default": 768
    },
    {
      "type": "range",
      "id": "breakpoint_mobile",
      "label": "Breakpoint mobile (px)",
      "min": 320,
      "max": 600,
      "step": 8,
      "default": 480
    }
