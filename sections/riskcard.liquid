  "blocks": [
    {
      "type": "card",
      "name": "Carte risque",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icône (emoji)",
          "default": "⚡"
        },
        {
          "type": "color",
          "id": "icon_bg",
          "label": "Fond icône (override)",
          "info": "Laissez vide pour utiliser la couleur globale"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Coupures d'électricité"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Prolongées, elles coupent l'accès à l'eau, au chauffage et aux communications."
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Couleur titre (override)",
          "info": "Laissez vide pour utiliser la couleur globale"
        },
        {
          "type": "color",
          "id": "desc_color",
          "label": "Couleur description (override)",
          "info": "Laissez vide pour utiliser la couleur globale"
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Fond de la carte (override)",
          "info": "Laissez vide pour utiliser la couleur globale"
        },
        {
          "type": "color",
          "id": "card_border_color",
          "label": "Bordure de la carte (override)",
          "info": "Laissez vide pour utiliser la couleur globale"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cartes risques",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon": "⚡",
            "title": "Coupures d'électricité",
            "description": "Prolongées, elles coupent l'accès à l'eau, au chauffage et aux communications."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "🌊",
            "title": "Catastrophes naturelles",
            "description": "Inondations, tempêtes ou séismes peuvent bloquer l'accès aux ressources."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "🚨",
            "title": "Évacuations d'urgence",
            "description": "Quitter son domicile rapidement sans avoir rien préparé est une situation difficile."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon": "📡",
            "title": "Pannes de réseaux",
            "description": "Internet, téléphone, transports : une panne simultanée isole efficacement."
          }
        }
      ]
    }
  ]
}
{% endschema %}
