{% comment %}
  Section : Comprendre les risques
  Fichier  : sections/risk-cards.liquid
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Epilogue:wght@600;700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  #shopify-section-{{ section.id }} .risk-s__tag,
  #shopify-section-{{ section.id }} .risk-s__lead,
  #shopify-section-{{ section.id }} .risk-s__card-desc {
    font-family: 'DM Sans', sans-serif;
  }

  #shopify-section-{{ section.id }} .risk-s__title,
  #shopify-section-{{ section.id }} .risk-s__card-title {
    font-family: 'Epilogue', sans-serif;
  }

  #shopify-section-{{ section.id }} .risk-s {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_v }}px {{ section.settings.padding_h }}px;
  }

  #shopify-section-{{ section.id }} .risk-s__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
  }

  /* ── TAG ── */
  #shopify-section-{{ section.id }} .risk-s__tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: {{ section.settings.tag_color }};
    font-size: {{ section.settings.tag_size }}px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: {{ section.settings.tag_mb }}px;
  }

  {% if section.settings.show_tag_line %}
  #shopify-section-{{ section.id }} .risk-s__tag::before {
    content: '';
    width: {{ section.settings.tag_line_width }}px;
    height: 2px;
    background-color: {{ section.settings.tag_color }};
    border-radius: 1px;
    display: inline-block;
  }
  {% endif %}

  /* ── TITRE ── */
  #shopify-section-{{ section.id }} .risk-s__title {
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.2;
    margin-bottom: {{ section.settings.title_mb }}px;
    max-width: {{ section.settings.title_max_width }}px;
  }

  /* ── LEAD ── */
  #shopify-section-{{ section.id }} .risk-s__lead {
    color: {{ section.settings.lead_color }};
    font-size: {{ section.settings.lead_size }}px;
    line-height: 1.7;
    font-weight: 300;
    max-width: {{ section.settings.lead_max_width }}px;
    margin-bottom: {{ section.settings.lead_mb }}px;
  }

  /* ── GRILLE ── */
  #shopify-section-{{ section.id }} .risk-s__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  /* ── CARTE ── */
  #shopify-section-{{ section.id }} .risk-s__card {
    background-color: {{ section.settings.card_bg }};
    border: {{ section.settings.card_border_width }}px solid {{ section.settings.card_border_color }};
    border-radius: {{ section.settings.card_radius }}px;
    padding: {{ section.settings.card_pad_v }}px {{ section.settings.card_pad_h }}px;
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.card_gap }}px;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  {% if section.settings.card_hover %}
  #shopify-section-{{ section.id }} .risk-s__card:hover {
    box-shadow: 0 8px 28px rgba(31, 58, 95, 0.12);
    transform: translateY(-2px);
  }
  {% endif %}

  /* ── ICÔNE ── */
  #shopify-section-{{ section.id }} .risk-s__icon {
    width: {{ section.settings.icon_box_size }}px;
    height: {{ section.settings.icon_box_size }}px;
    border-radius: {{ section.settings.icon_radius }}px;
    background: {{ section.settings.icon_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.icon_size }}px;
    flex-shrink: 0;
  }

  /* ── TEXTE ── */
  #shopify-section-{{ section.id }} .risk-s__card-title {
    font-size: {{ section.settings.card_title_size }}px;
    font-weight: {{ section.settings.card_title_weight }};
    color: {{ section.settings.card_title_color }};
    line-height: 1.3;
    margin: 0;
  }

  #shopify-section-{{ section.id }} .risk-s__card-desc {
    font-size: {{ section.settings.card_desc_size }}px;
    color: {{ section.settings.card_desc_color }};
    line-height: 1.6;
    margin: 0;
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: {{ section.settings.breakpoint_tablet }}px) {
    #shopify-section-{{ section.id }} .risk-s__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }

  @media screen and (max-width: {{ section.settings.breakpoint_mobile }}px) {
    #shopify-section-{{ section.id }} .risk-s__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
      gap: {{ section.settings.grid_gap | times: 0.75 | round }}px;
    }
    #shopify-section-{{ section.id }} .risk-s {
      padding: {{ section.settings.padding_v | divided_by: 1.4 | round }}px {{ section.settings.padding_h | divided_by: 1.5 | round }}px;
    }
    #shopify-section-{{ section.id }} .risk-s__title {
      font-size: {{ section.settings.title_size | times: 0.75 | round }}px;
    }
  }
</style>

<section class="risk-s">
  <div class="risk-s__inner">

    {%- if section.settings.tag != blank -%}
      <div class="risk-s__tag">{{ section.settings.tag }}</div>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <{{ section.settings.title_tag }} class="risk-s__title">
        {{ section.settings.title }}
      </{{ section.settings.title_tag }}>
    {%- endif -%}

    {%- if section.settings.lead != blank -%}
      <p class="risk-s__lead">{{ section.settings.lead }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="risk-s__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            <div class="risk-s__card" {{ block.shopify_attributes }}
              style="
                {% if block.settings.card_bg != blank %}background-color: {{ block.settings.card_bg }};{% endif %}
                {% if block.settings.card_border_color != blank %}border-color: {{ block.settings.card_border_color }};{% endif %}
              ">
              {%- if block.settings.icon != blank -%}
                <div class="risk-s__icon"
                  style="{% if block.settings.icon_bg != blank %}background: {{ block.settings.icon_bg }};{% endif %}">
                  {{ block.settings.icon }}
                </div>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="risk-s__card-title"
                  style="{% if block.settings.title_color != blank %}color: {{ block.settings.title_color }};{% endif %}">
                  {{ block.settings.title }}
                </h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="risk-s__card-desc"
                  style="{% if block.settings.desc_color != blank %}color: {{ block.settings.desc_color }};{% endif %}">
                  {{ block.settings.description }}
                </p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Cartes risques",
  "tag": "section",
  "class": "section-risk-cards",
  "settings": [
    {
      "type": "header",
      "content": "🎨 Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond de la section",
      "default": "#F2F4F7"
    },
    {
      "type": "header",
      "content": "📐 Mise en page"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur max (px)",
      "min": 600,
      "max": 1400,
      "step": 20,
      "default": 700
    },
    {
      "type": "range",
      "id": "padding_v",
      "label": "Espacement vertical (px)",
      "min": 20,
      "max": 120,
      "step": 4,
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_h",
      "label": "Espacement horizontal (px)",
      "min": 8,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "🏷️ Tag"
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Texte du tag",
      "default": "Comprendre les risques"
    },
    {
      "type": "color",
      "id": "tag_color",
      "label": "Couleur du tag",
      "default": "#F59E0B"
    },
    {
      "type": "range",
      "id": "tag_size",
      "label": "Taille du tag (px)",
      "min": 9,
      "max": 16,
      "step": 1,
      "default": 11
    },
    {
      "type": "range",
      "id": "tag_mb",
      "label": "Espace sous le tag (px)",
      "min": 4,
      "max": 32,
      "step": 2,
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_tag_line",
      "label": "Afficher la ligne avant le tag",
      "default": true
    },
    {
      "type": "range",
      "id": "tag_line_width",
      "label": "Longueur de la ligne (px)",
      "min": 10,
      "max": 60,
      "step": 2,
      "default": 24
    },
    {
      "type": "header",
      "content": "✍️ Titre"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre",
      "default": "Des situations qui peuvent arriver à tous"
    },
    {
      "type": "select",
      "id": "title_tag",
      "label": "Balise HTML",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille du titre (px)",
      "min": 18,
      "max": 60,
      "step": 2,
      "default": 36
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Graisse du titre",
      "options": [
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "900"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur du titre",
      "default": "#1a2332"
    },
    {
      "type": "range",
      "id": "title_max_width",
      "label": "Largeur max titre (px)",
      "min": 300,
      "max": 900,
      "step": 20,
      "default": 680
    },
    {
      "type": "range",
      "id": "title_mb",
      "label": "Espace sous le titre (px)",
      "min": 8,
      "max": 48,
      "step": 2,
      "default": 16
    },
    {
      "type": "header",
      "content": "📝 Texte d'introduction"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Texte d'introduction",
      "default": "Certaines situations courantes peuvent perturber votre quotidien en quelques heures et rendre temporairement inaccessibles l'électricité, l'eau ou les commerces."
    },
    {
      "type": "color",
      "id": "lead_color",
      "label": "Couleur du texte intro",
      "default": "#4a5568"
    },
    {
      "type": "range",
      "id": "lead_size",
      "label": "Taille du texte intro (px)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "lead_max_width",
      "label": "Largeur max intro (px)",
      "min": 300,
      "max": 900,
      "step": 20,
      "default": 660
    },
    {
      "type": "range",
      "id": "lead_mb",
      "label": "Espace sous l'intro (px)",
      "min": 12,
      "max": 60,
      "step": 4,
      "default": 36
    },
    {
      "type": "header",
      "content": "🃏 Cartes"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond des cartes",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Couleur bordure",
      "default": "#E4E8EF"
    },
    {
      "type": "range",
      "id": "card_border_width",
      "label": "Épaisseur bordure (px)",
      "min": 0,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Arrondi des cartes (px)",
      "min": 0,
      "max": 32,
      "step": 2,
      "default": 12
    },
    {
      "type": "range",
      "id": "card_pad_v",
      "label": "Padding vertical carte (px)",
      "min": 12,
      "max": 48,
      "step": 2,
      "default": 22
    },
    {
      "type": "range",
      "id": "card_pad_h",
      "label": "Padding horizontal carte (px)",
      "min": 12,
      "max": 48,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "card_gap",
      "label": "Espace entre les éléments de la carte (px)",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 10
    },
    {
      "type": "checkbox",
      "id": "card_hover",
      "label": "Effet hover sur les cartes",
      "default": true
    },
    {
      "type": "header",
      "content": "🔷 Icônes"
    },
    {
      "type": "color",
      "id": "icon_bg",
      "label": "Fond de l'icône",
      "default": "#e8f0fb"
    },
    {
      "type": "range",
      "id": "icon_box_size",
      "label": "Taille du bloc icône (px)",
      "min": 28,
      "max": 72,
      "step": 2,
      "default": 44
    },
    {
      "type": "range",
      "id": "icon_radius",
      "label": "Arrondi bloc icône (px)",
      "min": 0,
      "max": 36,
      "step": 2,
      "default": 10
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Taille de l'emoji/icône (px)",
      "min": 14,
      "max": 40,
      "step": 2,
      "default": 22
    },
    {
      "type": "header",
      "content": "📋 Texte des cartes"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Couleur titre carte",
      "default": "#1F3A5F"
    },
    {
      "type": "range",
      "id": "card_title_size",
      "label": "Taille titre carte (px)",
      "min": 11,
      "max": 22,
      "step": 1,
      "default": 14
    },
    {
      "type": "select",
      "id": "card_title_weight",
      "label": "Graisse titre carte",
      "options": [
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "color",
      "id": "card_desc_color",
      "label": "Couleur description carte",
      "default": "#4a5568"
    },
    {
      "type": "range",
      "id": "card_desc_size",
      "label": "Taille description carte (px)",
      "min": 11,
      "max": 18,
      "step": 1,
      "default": 13
    },
    {
      "type": "header",
      "content": "📱 Grille & Responsive"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Espace entre les cartes (px)",
      "min": 8,
      "max": 40,
      "step": 2,
      "default": 14
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Colonnes desktop",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "columns_tablet",
      "label": "Colonnes tablette",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Colonnes mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "breakpoint_tablet",
