{% comment %}
  BLOC : Contenu du kit
  ─────────────────────────────────────────────────────────────────
  1. Copie ce fichier dans snippets/block-kit-contents.liquid
  2. Dans ta section main-product.liquid (ou featured-product.liquid),
     ajoute dans le {% for block in section.blocks %}...{% endfor %} :

       {%- when 'kit_contents' -%}
         {%- render 'block-kit-contents', block: block -%}

  3. Ajoute le schéma du bloc (ci-dessous) dans le tableau "blocks"
     de ta section main-product.
  ─────────────────────────────────────────────────────────────────
{% endcomment %}

<style>
  .kit-block-{{ block.id }} {
    margin: {{ block.settings.margin_v }}px 0;
  }

  .kit-block-{{ block.id }} .kit-b__card {
    background-color: {{ block.settings.card_bg }};
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.card_radius }}px;
    padding: {{ block.settings.card_pad_v }}px {{ block.settings.card_pad_h }}px;
  }

  /* ── TITRE ── */
  .kit-block-{{ block.id }} .kit-b__title-wrap {
    text-align: center;
    margin-bottom: {{ block.settings.title_mb }}px;
  }

  .kit-block-{{ block.id }} .kit-b__title {
    display: inline-block;
    background-color: {{ block.settings.title_bg }};
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    letter-spacing: 0.02em;
    text-transform: {{ block.settings.title_transform }};
    padding: {{ block.settings.title_pad_v }}px {{ block.settings.title_pad_h }}px;
    border-radius: {{ block.settings.title_radius }}px;
    line-height: 1.2;
    margin: 0;
  }

  /* ── BODY ── */
  .kit-block-{{ block.id }} .kit-b__body {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    {% if block.settings.reverse_columns %}flex-direction: row-reverse;{% endif %}
  }

  /* ── IMAGE ── */
  .kit-block-{{ block.id }} .kit-b__media {
    flex: 0 0 {{ block.settings.image_width }}%;
    max-width: {{ block.settings.image_width }}%;
  }

  .kit-block-{{ block.id }} .kit-b__img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_radius }}px;
    object-fit: contain;
  }

  /* ── LISTE ── */
  .kit-block-{{ block.id }} .kit-b__list {
    flex: 1;
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.items_gap }}px;
  }

  .kit-block-{{ block.id }} .kit-b__item {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: {{ block.settings.text_size }}px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    line-height: 1.45;
  }

  .kit-block-{{ block.id }} .kit-b__qty {
    font-weight: 700;
    color: {{ block.settings.qty_color }};
    flex-shrink: 0;
  }

  /* ── RESPONSIVE ── */
  @media screen and (max-width: 640px) {
    .kit-block-{{ block.id }} .kit-b__body {
      flex-direction: column;
    }
    .kit-block-{{ block.id }} .kit-b__media {
      flex: 0 0 75%;
      max-width: 75%;
      margin: 0 auto;
    }
    .kit-block-{{ block.id }} .kit-b__title {
      font-size: {{ block.settings.title_size | times: 0.72 | round }}px;
    }
  }
</style>

<div class="kit-block-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="kit-b__card">

    {%- if block.settings.title != blank -%}
      <div class="kit-b__title-wrap">
        <p class="kit-b__title">{{ block.settings.title }}</p>
      </div>
    {%- endif -%}

    <div class="kit-b__body">

      {%- comment %} IMAGE {%- endcomment %}
      <div class="kit-b__media">
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            alt="{{ block.settings.image.alt | escape }}"
            width="600"
            loading="lazy"
            class="kit-b__img"
          >
        {%- elsif product.featured_image != blank -%}
          <img
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.featured_image.alt | escape }}"
            width="600"
            loading="lazy"
            class="kit-b__img"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'kit-b__img' }}
        {%- endif -%}
      </div>

      {%- comment %} LISTE {%- endcomment %}
      <ul class="kit-b__list">
        {%- assign items = block.settings.items_text | split: '|' -%}
        {%- for item in items -%}
          {%- assign item = item | strip -%}
          {%- if item != blank -%}
            {%- assign parts = item | split: ';;' -%}
            <li class="kit-b__item">
              {%- if parts.size > 1 -%}
                <span class="kit-b__qty">{{ parts[0] | strip }}</span>
                <span>{{ parts[1] | strip }}</span>
              {%- else -%}
                <span>{{ item }}</span>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

    </div>
  </div>
</div>


{% comment %}
════════════════════════════════════════════════════════════════════
  SCHÉMA À COLLER dans le tableau "blocks" de ta section main-product
  (entre les accolades du tableau blocks: [...] )
════════════════════════════════════════════════════════════════════

{
  "type": "kit_contents",
  "name": "Contenu du kit",
  "settings": [
    {
      "type": "header",
      "content": "✍️ Titre"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre du bloc",
      "default": "CONTENU DE VOTRE KIT DE SURVIE 72H"
    },
    {
      "type": "color",
      "id": "title_bg",
      "label": "Fond badge titre",
      "default": "#2d6a4f"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Couleur texte titre",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille titre (px)",
      "min": 12,
      "max": 36,
      "step": 1,
      "default": 22
    },
    {
      "type": "select",
      "id": "title_weight",
      "label": "Graisse titre",
      "options": [
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" },
        { "value": "800", "label": "Extra-Bold" },
        { "value": "900", "label": "Black" }
      ],
      "default": "800"
    },
    {
      "type": "select",
      "id": "title_transform",
      "label": "Casse titre",
      "options": [
        { "value": "uppercase", "label": "MAJUSCULES" },
        { "value": "none", "label": "Normal" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "title_pad_v",
      "label": "Padding vertical badge (px)",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 10
    },
    {
      "type": "range",
      "id": "title_pad_h",
      "label": "Padding horizontal badge (px)",
      "min": 10,
      "max": 50,
      "step": 2,
      "default": 24
    },
    {
      "type": "range",
      "id": "title_radius",
      "label": "Arrondi badge (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 50
    },
    {
      "type": "range",
      "id": "title_mb",
      "label": "Espace sous le titre (px)",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "header",
      "content": "🖼️ Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image du kit",
      "info": "Si vide, utilise l'image principale du produit"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Largeur image (%)",
      "min": 25,
      "max": 55,
      "step": 2,
      "default": 38
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Arrondi image (px)",
      "min": 0,
      "max": 20,
      "step": 2,
      "default": 8
    },
    {
      "type": "header",
      "content": "📋 Articles du kit"
    },
    {
      "type": "textarea",
      "id": "items_text",
      "label": "Liste des articles",
      "default": "1 x;;Sac à dos tactique 25L|1 x;;Lanterne LED|1 x;;Système de filtration d'eau 4000L|1 x;;Allume feu|1 x;;Corde Paracord Ø 4 mm, 25 m|1 x;;Radio d'urgence 10000mAh Solaire multifonctions|4 x;;Bâtons lumineux vert autonomie 12h|10 x;;Barres de rations de survie 12000 calories|1 x;;Couteau avec foureau|1 x;;Trousse de premiers secours (108 pièces)|2 x;;Couverture de survie|2 x;;Sifflets|1 x;;10 lingettes hygiéniques",
      "info": "Format : QTÉ;;Description | QTÉ;;Description. Séparez chaque article par | et la quantité du texte par ;;"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Taille du texte (px)",
      "min": 11,
      "max": 20,
      "step": 1,
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du texte",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "qty_color",
      "label": "Couleur des quantités",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "items_gap",
      "label": "Espace entre les lignes (px)",
      "min": 4,
      "max": 24,
      "step": 2,
      "default": 10
    },
    {
      "type": "header",
      "content": "🎨 Carte & Mise en page"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Fond de la carte",
      "default": "#e8f5ee"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Couleur bordure",
      "default": "#2d6a4f"
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Épaisseur bordure (px)",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Arrondi carte (px)",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 18
    },
    {
      "type": "range",
      "id": "card_pad_v",
      "label": "Padding vertical carte (px)",
      "min": 12,
      "max": 60,
      "step": 4,
      "default": 28
    },
    {
      "type": "range",
      "id": "card_pad_h",
      "label": "Padding horizontal carte (px)",
      "min": 12,
      "max": 60,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espace image ↔ liste (px)",
      "min": 8,
      "max": 60,
      "step": 4,
      "default": 32
    },
    {
      "type": "range",
      "id": "margin_v",
      "label": "Marge verticale du bloc (px)",
      "min": 0,
      "max": 40,
      "step": 4,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "reverse_columns",
      "label": "Image à droite",
      "default": false
    }
  ]
}

{% endcomment %}